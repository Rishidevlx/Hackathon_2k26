# =============================================
# 🔒 ROOT .gitignore — Pattern Matching App
# =============================================

# ── Dependencies ─────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ────────────────────────────
dist/
dist-ssr/
build/
.vite/

# ── Environment Variables (NEVER commit!) ────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*
backend/.env
backend/.env.*
admin/.env
admin/.env.*

# ── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── SSL / Secrets ────────────────────────────
*.pem
*.key
*.cert
secrets.json
credentials.json
service-account*.json

# ── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ──────────────────────────────────
coverage/
*.test.js.snap

# ── Misc ─────────────────────────────────────
*.local
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
